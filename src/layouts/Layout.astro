---
interface Props {
  title: string;
  description: string;
  page?: 'index' | 'advanced';
}
const { title, description, page = 'index' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>

<nav>
  <a class="nav-logo" href="/"><span>a2</span>native</a>
  {page === 'index' ? (
    <ul class="nav-links">
      <li><a href="#demo">Demo</a></li>
      <li><a href="#problem">Problem</a></li>
      <li><a href="#protocol">Protocol</a></li>
      <li><a href="#security">Security</a></li>
      <li><a href="#agents">For Agents</a></li>
      <li><a href="advanced.html">Advanced ↗</a></li>
    </ul>
  ) : (
    <ul class="nav-links">
      <li><a href="/">← Docs</a></li>
      <li><a href="#session" class="active">Sessions</a></li>
      <li><a href="#sse-ws" class="active">SSE / WS</a></li>
    </ul>
  )}
  <a class="nav-gh" href="https://github.com/a2native/a2native" target="_blank">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
    GitHub
  </a>
</nav>

<slot />

<footer>
  <p>
    <strong>a2native</strong> · Apache-2.0 ·
    <a href="https://github.com/a2native/a2native">GitHub</a> ·
    <a href="https://github.com/a2native/a2native/blob/main/README.zh.md">中文文档</a> ·
    <a href="https://a2native.github.io/schema/a2native-v0.1.schema.json">Input Schema</a>
  </p>
  <p style="margin-top:0.5rem">Built with <a href="https://github.com/emilk/egui">egui</a> · Inspired by <a href="https://github.com/vercel-labs/agent-browser">agent-browser</a> · See also <a href="https://github.com/google/a2ui">Google A2UI</a> · <a href="https://github.com/ag-ui-protocol/ag-ui">AG-UI</a> (web streaming)</p>
</footer>

</body>
</html>
